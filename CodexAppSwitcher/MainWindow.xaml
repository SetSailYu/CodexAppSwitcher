                                                            <Setter Property="Background" Value="#173620" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding CurrentAccountStatus}" FontSize="11">
