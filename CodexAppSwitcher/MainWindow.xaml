                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsTakeoverPending}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Grid>
                                                            <StackPanel Orientation="Horizontal"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center">
                                                                <StackPanel.Style>
                                                                    <Style TargetType="{x:Type StackPanel}">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsCapturing}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </StackPanel.Style>
                                                                <ProgressBar Width="16"
                                                                             Height="5"
                                                                             IsIndeterminate="True"
                                                                             Margin="0,0,5,0"
                                                                             VerticalAlignment="Center" />
                                                                <TextBlock Text="接管中" FontSize="12" VerticalAlignment="Center" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </Button>
                                                    <Button Command="{Binding DataContext.TakeoverCodexAppCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Width="66"
                                                            Height="30"
                                                            Margin="0,0,6,0"
                                                            MinWidth="0"
                                                            Padding="0"
                                                            ToolTip="用当前 Codex App 登录态更新此账号快照。">
                                                        <Button.Style>
                                                            <Style TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <MultiDataTrigger>
                                                                        <MultiDataTrigger.Conditions>
                                                                            <Condition Binding="{Binding IsManaged}" Value="True" />
                                                                            <Condition Binding="{Binding IsCurrent}" Value="True" />
                                                                        </MultiDataTrigger.Conditions>
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </MultiDataTrigger>
                                                                    <DataTrigger Binding="{Binding DataContext.IsCodexAppCapturing, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                                        <Setter Property="IsHitTestVisible" Value="False" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding DataContext.IsAccountSwitching, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                                        <Setter Property="IsHitTestVisible" Value="False" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                        <Grid Width="60">
                                                            <TextBlock Text="更新"
                                                                       FontSize="12"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center">
