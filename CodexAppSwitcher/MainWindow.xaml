                                                    CornerRadius="7">
                                                <Border.Style>
                                                    <Style TargetType="{x:Type Border}">
                                                        <Setter Property="Background" Value="#0F1A27" />
                                                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
