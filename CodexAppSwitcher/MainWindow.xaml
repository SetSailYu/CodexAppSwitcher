                                                            <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                                <Setter Property="Background" Value="#102A22" />
                                                                <Setter Property="BorderBrush" Value="#2F7A4B" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
