                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                            </ScrollViewer>

                            <Grid Grid.Column="1"
                                  Margin="8,0,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="42" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Border Background="{StaticResource PanelAltBrush}"
                                        CornerRadius="6"
                                        BorderBrush="{StaticResource BorderBrush}"
