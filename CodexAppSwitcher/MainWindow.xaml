                                                    <Style TargetType="{x:Type Ellipse}">
                                                        <Setter Property="Fill" Value="{StaticResource TextMutedBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCodexAppRunning}" Value="True">
                                                                <Setter Property="Fill" Value="{StaticResource SuccessBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <TextBlock Text="Codex App"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="12"
                                                       Margin="8,0,0,0"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                        <TextBlock DockPanel.Dock="Right"
                                                   Text="{Binding CodexAppRunStateText}"
                                                   FontSize="12">
                                            <TextBlock.Style>
                                                <Style TargetType="{x:Type TextBlock}">
                                                    <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCodexAppRunning}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
