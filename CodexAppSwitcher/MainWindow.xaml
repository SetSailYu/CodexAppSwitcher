                                <ItemsControl Grid.Row="1"
                                              ItemsSource="{Binding Accounts}"
                                              Margin="0,6,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Height="56"
                                                    Margin="0,0,0,5"
