                                                            <Style TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
                                                                <Style.Triggers>
                                                                    <MultiDataTrigger>
                                                                        <MultiDataTrigger.Conditions>
                                                                            <Condition Binding="{Binding IsManaged}" Value="True" />
                                                                            <Condition Binding="{Binding IsCurrent}" Value="True" />
                                                                        </MultiDataTrigger.Conditions>
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </MultiDataTrigger>
                                                                    <DataTrigger Binding="{Binding DataContext.IsCodexAppCapturing, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                                        <Setter Property="IsHitTestVisible" Value="False" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding DataContext.IsAccountSwitching, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                                        <Setter Property="IsHitTestVisible" Value="False" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                        <Grid Width="60">
                                                            <Grid HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center">
                                                                <Grid.Style>
                                                                    <Style TargetType="{x:Type Grid}">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsCapturing}" Value="True">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Grid.Style>
                                                                <TextBlock Text="{Binding TakeoverActionText}"
                                                                           FontSize="12"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="{x:Type TextBlock}">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsTakeoverPending}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                                <TextBlock Text="完成"
                                                                           FontSize="12"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center">
