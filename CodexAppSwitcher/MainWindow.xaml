<Window x:Class="CodexAppSwitcher.MainWindow"
        x:Name="RootWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="CodexAppSwitcher"
        Width="1680"
        Height="945"
        MinWidth="1280"
        MinHeight="760"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Icon="{StaticResource AppLogoIcon}"
        Background="{StaticResource AppBackgroundBrush}"
        Loaded="Window_OnLoaded">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            NonClientFrameEdges="None"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style TargetType="{x:Type ContextMenu}">
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="5" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ContextMenu}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="{x:Type MenuItem}">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="MinWidth" Value="205" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="ToolTipService.ShowOnDisabled" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type MenuItem}">
                        <Border x:Name="MenuItemRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter ContentSource="Header"
                                              RecognizesAccessKey="True"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="MenuItemRoot" Property="Background" Value="#1A3147" />
                                <Setter TargetName="MenuItemRoot" Property="BorderBrush" Value="#2E5876" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="MenuItemRoot" Property="Opacity" Value="0.45" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DangerMenuItemStyle" TargetType="{x:Type MenuItem}">
            <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
            <Setter Property="Background" Value="#241018" />
            <Setter Property="BorderBrush" Value="#4B1B28" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="MinWidth" Value="205" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="ToolTipService.ShowOnDisabled" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type MenuItem}">
                        <Border x:Name="DangerMenuItemRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <TextBlock Text="{TemplateBinding Header}"
                                       Foreground="{TemplateBinding Foreground}"
                                       VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="DangerMenuItemRoot" Property="Background" Value="#3B1420" />
                                <Setter TargetName="DangerMenuItemRoot" Property="BorderBrush" Value="{StaticResource DangerBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="DangerMenuItemRoot" Property="Background" Value="Transparent" />
                                <Setter TargetName="DangerMenuItemRoot" Property="BorderBrush" Value="Transparent" />
                                <Setter TargetName="DangerMenuItemRoot" Property="Opacity" Value="0.5" />
                                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                    <Setter Property="IsEnabled" Value="False" />
                    <Setter Property="ToolTip" Value="当前使用账号不能删除，请先切换到其他账号。" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="{x:Type Separator}">
            <Setter Property="Margin" Value="8,5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Separator}">
                        <Border Height="1"
                                Background="{StaticResource BorderBrush}"
                                Opacity="0.8" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <DrawingImage x:Key="PlusIcon">
            <DrawingImage.Drawing>
                <GeometryDrawing Geometry="M12,5 L12,19 M5,12 L19,12">
                    <GeometryDrawing.Pen>
                        <Pen Brush="{StaticResource TextPrimaryBrush}" Thickness="2" StartLineCap="Round" EndLineCap="Round" />
                    </GeometryDrawing.Pen>
                </GeometryDrawing>
            </DrawingImage.Drawing>
        </DrawingImage>
        <DrawingImage x:Key="RefreshIcon">
            <DrawingImage.Drawing>
                <GeometryDrawing Geometry="M20,12 C20,7.6 16.4,4 12,4 C9.3,4 6.9,5.3 5.5,7.3 M4,4 L4,8 L8,8 M4,12 C4,16.4 7.6,20 12,20 C14.7,20 17.1,18.7 18.5,16.7 M20,20 L20,16 L16,16">
                    <GeometryDrawing.Pen>
                        <Pen Brush="{StaticResource TextPrimaryBrush}" Thickness="1.9" StartLineCap="Round" EndLineCap="Round" LineJoin="Round" />
                    </GeometryDrawing.Pen>
                </GeometryDrawing>
            </DrawingImage.Drawing>
        </DrawingImage>
        <DrawingImage x:Key="PlayIcon">
            <DrawingImage.Drawing>
                <GeometryDrawing Geometry="M8,5 L19,12 L8,19 Z">
                    <GeometryDrawing.Pen>
                        <Pen Brush="{StaticResource TextPrimaryBrush}" Thickness="1.8" StartLineCap="Round" EndLineCap="Round" LineJoin="Round" />
                    </GeometryDrawing.Pen>
                </GeometryDrawing>
            </DrawingImage.Drawing>
        </DrawingImage>
        <DrawingImage x:Key="StopIcon">
            <DrawingImage.Drawing>
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="{StaticResource DangerBrush}" Thickness="1.8" StartLineCap="Round" EndLineCap="Round" LineJoin="Round" />
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="8,8,8,8" RadiusX="0.5" RadiusY="0.5" />
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingImage.Drawing>
        </DrawingImage>
        <DrawingImage x:Key="AccountIcon">
            <DrawingImage.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="{x:Null}">
                        <GeometryDrawing.Pen>
                            <Pen Brush="{StaticResource TextPrimaryBrush}" Thickness="1.9" StartLineCap="Round" EndLineCap="Round" />
                        </GeometryDrawing.Pen>
                        <GeometryDrawing.Geometry>
                            <EllipseGeometry Center="12,8" RadiusX="3.5" RadiusY="3.5" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Geometry="M5,20 C5.8,16.5 8.5,14.5 12,14.5 C15.5,14.5 18.2,16.5 19,20">
                        <GeometryDrawing.Pen>
                            <Pen Brush="{StaticResource TextPrimaryBrush}" Thickness="1.9" StartLineCap="Round" EndLineCap="Round" />
                        </GeometryDrawing.Pen>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingImage.Drawing>
        </DrawingImage>
        <DrawingImage x:Key="UsageIcon">
            <DrawingImage.Drawing>
                <GeometryDrawing Geometry="M12,3 A9,9 0 1 0 21,12 L12,12 Z M12,3 L12,12 L21,12">
                    <GeometryDrawing.Pen>
                        <Pen Brush="{StaticResource TextPrimaryBrush}" Thickness="1.8" StartLineCap="Round" EndLineCap="Round" LineJoin="Round" />
                    </GeometryDrawing.Pen>
                </GeometryDrawing>
            </DrawingImage.Drawing>
        </DrawingImage>
        <DrawingImage x:Key="SwitchIcon">
            <DrawingImage.Drawing>
                <GeometryDrawing Geometry="M7,7 L19,7 M16,4 L19,7 L16,10 M17,17 L5,17 M8,14 L5,17 L8,20">
                    <GeometryDrawing.Pen>
                        <Pen Brush="{StaticResource TextPrimaryBrush}" Thickness="1.9" StartLineCap="Round" EndLineCap="Round" LineJoin="Round" />
                    </GeometryDrawing.Pen>
                </GeometryDrawing>
            </DrawingImage.Drawing>
        </DrawingImage>
        <DrawingImage x:Key="CheckCircleIcon">
            <DrawingImage.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="{StaticResource SuccessBrush}">
                        <GeometryDrawing.Geometry>
                            <EllipseGeometry Center="12,12" RadiusX="5.5" RadiusY="5.5" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Geometry="M9.5,12 L11.2,13.7 L14.8,10">
                        <GeometryDrawing.Pen>
                            <Pen Brush="{StaticResource AppBackgroundBrush}" Thickness="1.6" StartLineCap="Round" EndLineCap="Round" LineJoin="Round" />
                        </GeometryDrawing.Pen>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingImage.Drawing>
        </DrawingImage>
        <DrawingImage x:Key="TrashIcon">
            <DrawingImage.Drawing>
                <GeometryDrawing Geometry="M6,7 L18,7 M10,7 L10,5 L14,5 L14,7 M8,10 L8.5,19 L15.5,19 L16,10 M11,11 L11,17 M13,11 L13,17">
                    <GeometryDrawing.Pen>
                        <Pen Brush="{StaticResource TextMutedBrush}" Thickness="1.7" StartLineCap="Round" EndLineCap="Round" LineJoin="Round" />
                    </GeometryDrawing.Pen>
                </GeometryDrawing>
            </DrawingImage.Drawing>
        </DrawingImage>
        <DrawingImage x:Key="ExternalLinkIcon">
            <DrawingImage.Drawing>
                <GeometryDrawing Geometry="M14,5 L19,5 L19,10 M13,11 L19,5 M19,14 L19,19 L5,19 L5,5 L10,5">
                    <GeometryDrawing.Pen>
                        <Pen Brush="{StaticResource TextPrimaryBrush}" Thickness="1.8" StartLineCap="Round" EndLineCap="Round" LineJoin="Round" />
                    </GeometryDrawing.Pen>
                </GeometryDrawing>
            </DrawingImage.Drawing>
        </DrawingImage>
        <DrawingImage x:Key="MonitorIcon">
            <DrawingImage.Drawing>
                <GeometryDrawing Geometry="M4,5 L20,5 L20,16 L4,16 Z M9,20 L15,20 M12,16 L12,20">
                    <GeometryDrawing.Pen>
                        <Pen Brush="{StaticResource TextMutedBrush}" Thickness="1.8" StartLineCap="Round" EndLineCap="Round" LineJoin="Round" />
                    </GeometryDrawing.Pen>
                </GeometryDrawing>
            </DrawingImage.Drawing>
        </DrawingImage>
    </Window.Resources>
    <Border Background="{StaticResource AppBackgroundBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Background="#07111A"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                <DockPanel LastChildFill="False">
                    <StackPanel Orientation="Horizontal"
                                DockPanel.Dock="Left"
                                VerticalAlignment="Center"
                                Margin="16,0,0,0">
                        <Image Source="{StaticResource AppLogoIcon}"
                               Width="16"
                               Height="16"
                               Stretch="Uniform"
                               VerticalAlignment="Center" />
                        <TextBlock Text="CodexAppSwitcher"
                                   Margin="8,0,0,0"
                                   FontSize="13"
                                   FontWeight="Normal"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button Content="─"
                                Width="48"
                                Height="40"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                FontSize="14"
                                Click="MinimizeButton_OnClick" />
                        <Button Content="□"
                                Width="48"
                                Height="40"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                FontSize="13"
                                Click="MaximizeButton_OnClick" />
                        <Button Content="×"
                                Width="48"
                                Height="40"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                FontSize="16"
                                Click="CloseButton_OnClick" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="292" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="82" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="232" />
                    <RowDefinition Height="60" />
                </Grid.RowDefinitions>

                <Border Grid.Column="0"
                        Grid.ColumnSpan="2"
                        Background="#08131D"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="18,0,0,0">
                        <Button Command="{Binding AddChatGptAccountCommand}"
                                Width="176"
                                Height="44"
                                Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="{StaticResource PlusIcon}" Width="17" Height="17" Margin="0,0,10,0" />
                                <TextBlock Text="添加 ChatGPT 账号" FontSize="14" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding RefreshUsageCommand}"
                                Width="136"
                                Height="44"
                                Margin="0,0,8,0"
                                ToolTip="{Binding RefreshUsageTooltip}">
                            <Button.Style>
                                <Style TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsUsageRefreshing}" Value="True">
                                            <Setter Property="IsHitTestVisible" Value="False" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsUsageRefreshEnabled}" Value="False">
                                            <Setter Property="Opacity" Value="0.78" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Grid Width="104">
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center">
                                    <StackPanel.Style>
                                        <Style TargetType="{x:Type StackPanel}">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsUsageRefreshing}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <Image Source="{StaticResource RefreshIcon}" Width="17" Height="17" Margin="0,0,10,0" />
                                    <TextBlock Text="刷新用量" FontSize="14" VerticalAlignment="Center" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <StackPanel.Style>
                                        <Style TargetType="{x:Type StackPanel}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsUsageRefreshing}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <ProgressBar Width="34"
                                                 Height="6"
                                                 IsIndeterminate="True"
                                                 Margin="0,0,10,0"
                                                 VerticalAlignment="Center" />
                                    <TextBlock Text="刷新中" FontSize="14" VerticalAlignment="Center" />
                                </StackPanel>
                            </Grid>
                        </Button>
                        <Button Command="{Binding ToggleUsageWidgetCommand}"
                                Width="128"
                                Height="44"
                                Margin="0,0,8,0"
                                ToolTip="显示或隐藏当前账号额度桌面挂件">
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center">
                                <TextBlock Text="{Binding UsageWidgetButtonText}"
                                           FontSize="14"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding OpenCodexAppCommand}"
                                Width="154"
                                Height="44"
                                Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="{StaticResource PlayIcon}" Width="16" Height="16" Margin="0,0,10,0" />
                                <TextBlock Text="启动 Codex" FontSize="14" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding StopCodexAppCommand}"
                                Width="154"
                                Height="44">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="{StaticResource StopIcon}" Width="15" Height="15" Margin="0,0,12,0" />
                                <TextBlock Text="停止 Codex" FontSize="14" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1"
                        Grid.Column="0"
                        Margin="18,18,12,12"
                        Padding="14"
                        Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="40" />
                            <RowDefinition Height="42" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="{Binding AccountListTitle}"
                                   FontSize="18"
                                   FontWeight="Normal" />
                        <Grid Grid.Row="1"
                              Grid.RowSpan="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="184" />
                            </Grid.ColumnDefinitions>

                            <ScrollViewer Grid.Column="0"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled">
                            <Grid MinWidth="844"
                                  Width="{Binding ViewportWidth, RelativeSource={RelativeSource AncestorType=ScrollViewer}}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="42" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Border Background="{StaticResource PanelAltBrush}"
                                        CornerRadius="6"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1">
                                    <Grid Margin="16,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" MinWidth="230" />
                                            <ColumnDefinition Width="76" />
                                            <ColumnDefinition Width="128" />
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="128" />
                                            <ColumnDefinition Width="146" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="账号名称" VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" />
                                        <TextBlock Grid.Column="1" Text="状态" VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" />
                                        <TextBlock Grid.Column="2" Text="5 小时额度" VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" />
                                        <TextBlock Grid.Column="3" Text="5 小时重置" VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" />
                                        <TextBlock Grid.Column="4" Text="每周额度" VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" />
                                        <TextBlock Grid.Column="5" Text="每周重置" VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" />
                                    </Grid>
                                </Border>

                                <ItemsControl Grid.Row="1"
                                              ItemsSource="{Binding Accounts}"
                                              Margin="0,6,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Height="56"
                                                    Margin="0,0,0,5"
                                                    Padding="16,0"
                                                    BorderThickness="1"
                                                    CornerRadius="7"
                                                    Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                                                <Border.Style>
                                                    <Style TargetType="{x:Type Border}">
                                                        <Setter Property="Background" Value="#0F1A27" />
                                                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                                <Setter Property="Background" Value="#102A22" />
                                                                <Setter Property="BorderBrush" Value="#2F7A4B" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Border.ContextMenu>
                                                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                        <MenuItem Header="重命名账号"
                                                                  Command="{Binding PlacementTarget.Tag.RenameAccountCommand, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                                  CommandParameter="{Binding}" />
                                                        <MenuItem Header="打开 App 快照目录"
                                                                  Command="{Binding PlacementTarget.Tag.OpenAccountSnapshotDirectoryCommand, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                                  CommandParameter="{Binding}" />
                                                        <MenuItem Header="打开 Web 登录目录"
                                                                  Command="{Binding PlacementTarget.Tag.OpenAccountWebProfileDirectoryCommand, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                                  CommandParameter="{Binding}" />
                                                        <Separator />
                                                        <MenuItem Header="删除本地账号"
                                                                  Command="{Binding PlacementTarget.Tag.DeleteAccountCommand, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                                  CommandParameter="{Binding}"
                                                                  Style="{StaticResource DangerMenuItemStyle}" />
                                                    </ContextMenu>
                                                </Border.ContextMenu>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" MinWidth="230" />
                                                        <ColumnDefinition Width="76" />
                                                        <ColumnDefinition Width="128" />
                                                        <ColumnDefinition Width="90" />
                                                        <ColumnDefinition Width="128" />
                                                        <ColumnDefinition Width="146" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Orientation="Horizontal"
                                                                VerticalAlignment="Center">
                                                        <StackPanel.ToolTip>
                                                            <ToolTip DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                                                     Background="{StaticResource PanelAltBrush}"
                                                                     BorderBrush="{StaticResource AccentBrush}"
                                                                     BorderThickness="1"
                                                                     Padding="12"
                                                                     HasDropShadow="True">
                                                                <StackPanel Width="320">
                                                                    <TextBlock Text="{Binding DisplayName}"
                                                                               FontSize="13"
                                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                                               TextWrapping="Wrap" />
                                                                    <Border Height="1"
                                                                            Background="{StaticResource BorderBrush}"
                                                                            Margin="0,8,0,8" />
                                                                    <TextBlock Text="{Binding HealthText}"
                                                                               FontSize="12"
                                                                               Foreground="{StaticResource WarningBrush}" />
                                                                    <TextBlock Text="{Binding AccountHint}"
                                                                               FontSize="12"
                                                                               Foreground="{StaticResource TextMutedBrush}"
                                                                               TextWrapping="Wrap"
                                                                               Margin="0,6,0,0" />
                                                                </StackPanel>
                                                            </ToolTip>
                                                        </StackPanel.ToolTip>
                                                        <TextBlock Text="●"
                                                                   Margin="0,0,12,0">
                                                            <TextBlock.Style>
                                                                <Style TargetType="{x:Type TextBlock}">
                                                                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding HealthText}" Value="未接管">
                                                                            <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <StackPanel Width="210">
                                                            <TextBlock Text="{Binding DisplayName}"
                                                                       FontWeight="SemiBold"
                                                                       TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Text="{Binding AccountHint}"
                                                                       Foreground="{StaticResource TextMutedBrush}"
                                                                       FontSize="12"
                                                                       Margin="0,3,0,0"
                                                                       TextTrimming="CharacterEllipsis" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <Border Grid.Column="1"
                                                            Width="54"
                                                            Height="24"
                                                            CornerRadius="12"
                                                            HorizontalAlignment="Left"
                                                            VerticalAlignment="Center">
                                                        <Border.Style>
                                                            <Style TargetType="{x:Type Border}">
                                                                <Setter Property="Background" Value="#12341F" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HealthText}" Value="未接管">
                                                                        <Setter Property="Background" Value="#3A2A10" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
