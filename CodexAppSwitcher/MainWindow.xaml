                                                             Height="6"
                                                             Maximum="100"
                                                             Value="{Binding FiveHourProgressValue, Mode=OneWay}"
                                                             VerticalAlignment="Center" />
                                            </Grid>
                                            <TextBlock Text="{Binding FiveHourResetText, StringFormat=重置：{0}}"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="12"
                                                       Margin="74,0,0,10" />

                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="74" />
                                                    <ColumnDefinition Width="58" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="每周"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding WeeklyText}"
                                                           FontSize="15"
                                                           VerticalAlignment="Center" />
                                                <ProgressBar Grid.Column="2"
                                                             Height="6"
                                                             Maximum="100"
                                                             Value="{Binding WeeklyProgressValue, Mode=OneWay}"
