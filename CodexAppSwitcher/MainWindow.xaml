                                                            <DataTrigger Binding="{Binding IsPassed}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                            <Border Width="14" Height="14" CornerRadius="7" Background="{StaticResource WarningBrush}" VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="{x:Type Border}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsPassed}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="!" FontSize="10" Foreground="{StaticResource AppBackgroundBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <TextBlock Text="{Binding Text}" Margin="10,0,0,0" FontSize="13">
                                                <TextBlock.Style>
                                                    <Style TargetType="{x:Type TextBlock}">
                                                        <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsPassed}" Value="True">
                                                                <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2"
                        Grid.Column="0"
                        Margin="18,0,12,18"
                        Padding="14"
                        Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="34" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <DockPanel LastChildFill="False">
                            <TextBlock Text="操作日志" FontSize="16" FontWeight="Normal" VerticalAlignment="Center" />
                            <Button DockPanel.Dock="Right"
                                    Command="{Binding ClearOperationLogsCommand}"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    Padding="0"
                                    MinWidth="0"
                                    ToolTip="清空当前操作日志。">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Image Source="{StaticResource TrashIcon}" Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center" />
                                    <TextBlock Text="清空日志" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </DockPanel>
                        <Border Grid.Row="1"
                                Background="#061019"
                                CornerRadius="6"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                Padding="14">
                            <ScrollViewer x:Name="OperationLogScrollViewer"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding OperationLogs}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="142" />
                                                    <ColumnDefinition Width="18" />
                                                    <ColumnDefinition Width="44" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding TimeText}"
                                                           FontFamily="Consolas"
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextMutedBrush}" />
                                                <Ellipse Grid.Column="1"
                                                         Width="7"
                                                         Height="7"
                                                         VerticalAlignment="Center">
                                                    <Ellipse.Style>
                                                        <Style TargetType="{x:Type Ellipse}">
                                                            <Setter Property="Fill" Value="#60A5FA" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="成功">
                                                                    <Setter Property="Fill" Value="{StaticResource SuccessBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="警告">
                                                                    <Setter Property="Fill" Value="{StaticResource WarningBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding Status}"
                                                           FontSize="12"
                                                           FontWeight="Normal">
                                                    <TextBlock.Style>
                                                        <Style TargetType="{x:Type TextBlock}">
                                                            <Setter Property="Foreground" Value="#60A5FA" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="成功">
                                                                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="警告">
                                                                    <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Grid.Column="3"
                                                           Text="{Binding Message}"
                                                           FontFamily="Consolas"
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="3"
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,1,0,0">
                    <DockPanel LastChildFill="False" Margin="18,0">
                        <TextBlock Text="版本：1.1.0" VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" />
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding DataDirectoryText}" Foreground="{StaticResource TextMutedBrush}" />
                            <Button Command="{Binding OpenDataDirectoryCommand}"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    Padding="12,0,0,0"
                                    MinWidth="0"
                                    ToolTip="在资源管理器中打开 Switcher 数据目录。">
                                <TextBlock Text="打开目录" Foreground="#38A3FF" />
                            </Button>
                        </StackPanel>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
