                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding HasUsageData}" Value="False">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding IsWeeklyUsageWarning}" Value="True">
                                                                            <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding IsWeeklyUsageCritical}" Value="True">
                                                                            <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </ProgressBar.Style>
                                                        </ProgressBar>
