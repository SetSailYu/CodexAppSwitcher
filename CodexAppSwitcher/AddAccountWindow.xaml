<Window x:Class="CodexAppSwitcher.AddAccountWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="添加 ChatGPT 账号"
        Width="980"
        Height="720"
        MinWidth="860"
        MinHeight="620"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        Icon="{StaticResource AppLogoIcon}"
        Background="{StaticResource AppBackgroundBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        Loaded="Window_OnLoaded">
    <Window.Resources>
        <Style x:Key="PrimaryActionButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Foreground" Value="#052019" />
            <Setter Property="Background" Value="#1F5F55" />
            <Setter Property="BorderBrush" Value="#2A8A7A" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#277667" />
                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#16483F" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="42" />
            <RowDefinition Height="*" />
            <RowDefinition Height="92" />
        </Grid.RowDefinitions>

        <Border Background="#07111A"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal"
                            DockPanel.Dock="Left"
                            VerticalAlignment="Center"
                            Margin="16,0,0,0">
                    <Image Source="{StaticResource AppLogoIcon}"
                           Width="16"
                           Height="16"
                           Stretch="Uniform"
                           VerticalAlignment="Center" />
                    <TextBlock Text="添加 ChatGPT 账号"
                               Margin="8,0,0,0"
                               FontSize="13"
                               FontWeight="Normal"
                               VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Content="─"
                            Width="48"
                            Height="40"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            FontSize="14"
                            Click="MinimizeButton_OnClick" />
                    <Button Content="□"
                            Width="48"
                            Height="40"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            FontSize="13"
                            Click="MaximizeButton_OnClick" />
                    <Button Content="×"
                            Width="48"
                            Height="40"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            FontSize="16"
                            Click="CloseButton_OnClick" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1"
                Margin="16,14,16,0"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                ClipToBounds="True">
            <wv2:WebView2 x:Name="Browser" />
        </Border>

        <Grid Grid.Row="2" Margin="16,0,16,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="34" />
                <RowDefinition Height="44" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Grid.ColumnSpan="2"
                    Height="28"
                    Padding="10,0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Background="#112638"
                    BorderBrush="{StaticResource AccentBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                <DockPanel LastChildFill="True">
                    <Ellipse Width="8"
                             Height="8"
                             Margin="0,0,8,0"
                             Fill="{StaticResource AccentBrush}"
                             VerticalAlignment="Center" />
                    <TextBlock x:Name="StatusText"
                               Text="登录成功后会自动尝试打开账号菜单并识别邮箱，也可手动重新识别。"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="13"
                               VerticalAlignment="Center" />
                </DockPanel>
            </Border>
            <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock x:Name="DetectedText"
                           Text="账号 ID：等待识别"
                           Foreground="{StaticResource TextMutedBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,18,0" />
                <TextBlock Text="手动填写"
                           Foreground="{StaticResource TextMutedBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0" />
                <TextBox x:Name="ManualUserIdentifierTextBox"
                         Width="280"
                         Height="30"
                         Background="{StaticResource ControlBrush}"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         BorderBrush="{StaticResource BorderBrush}"
                         Padding="8,4"
                         VerticalContentAlignment="Center" />
            </StackPanel>
            <StackPanel Grid.Row="1"
                        Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Button Content="重新识别" Width="104" Height="34" Margin="0,0,8,0" Click="DetectButton_OnClick" />
                <Button Content="取消" Width="96" Height="34" Margin="0,0,8,0" Click="CancelButton_OnClick" />
                <Button Content="使用当前账号"
                        Width="136"
                        Height="34"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        Style="{StaticResource PrimaryActionButtonStyle}"
                        Click="UseCurrentButton_OnClick" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
